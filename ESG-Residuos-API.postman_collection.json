            "body": {
              "mode": "raw",
              "raw": "{\n  \"collectionId\": 1,\n  \"destinationName\": \"Cooperativa Verde\",\n  \"processingType\": \"RECICLAGEM\",\n  \"destinatedVolumeKg\": 420\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/destinations", "host": ["{{baseUrl}}"], "path": ["api", "destinations"] }
