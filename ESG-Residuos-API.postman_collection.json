{
  "info": {
    "name": "ESG Resíduos API",
    "description": "API para gestão de resíduos e reciclagem - FIAP 2025",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5016",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('token', json.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Lenon Merlo\",\n  \"email\": \"lenon@esg.com\",\n  \"password\": \"Test@1234\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register"] }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('token', json.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"lenon@esg.com\",\n  \"password\": \"Test@1234\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] }
          }
        }
      ]
    },
    {
      "name": "WasteTypes",
      "item": [
        {
          "name": "Get All WasteTypes",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/wastetypes?page=1&pageSize=10", "host": ["{{baseUrl}}"], "path": ["api", "wastetypes"], "query": [{ "key": "page", "value": "1" }, { "key": "pageSize", "value": "10" }] }
          }
        },
        {
          "name": "Get WasteType by Id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/wastetypes/1", "host": ["{{baseUrl}}"], "path": ["api", "wastetypes", "1"] }
          }
        },
        {
          "name": "Create WasteType",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"wasteCategory\": \"PLASTICO\",\n  \"description\": \"Resíduos plásticos recicláveis\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/wastetypes", "host": ["{{baseUrl}}"], "path": ["api", "wastetypes"] }
          }
        },
        {
          "name": "Update WasteType",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"wasteCategory\": \"PLASTICO\",\n  \"description\": \"Resíduos plásticos recicláveis - atualizado\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/wastetypes/1", "host": ["{{baseUrl}}"], "path": ["api", "wastetypes", "1"] }
          }
        },
        {
          "name": "Delete WasteType",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/wastetypes/1", "host": ["{{baseUrl}}"], "path": ["api", "wastetypes", "1"] }
          }
        }
      ]
    },
    {
      "name": "CollectionPoints",
      "item": [
        {
          "name": "Get All CollectionPoints",
          "request": {
