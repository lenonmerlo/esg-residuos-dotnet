    },
    {
      "name": "Destinations",
      "item": [
        {
          "name": "Get All Destinations",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/destinations?page=1&pageSize=10", "host": ["{{baseUrl}}"], "path": ["api", "destinations"], "query": [{ "key": "page", "value": "1" }, { "key": "pageSize", "value": "10" }] }
          }
        },
        {
          "name": "Get Destination by Id",
          "request": {
