            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/collectionalerts?page=1&pageSize=10", "host": ["{{baseUrl}}"], "path": ["api", "collectionalerts"], "query": [{ "key": "page", "value": "1" }, { "key": "pageSize", "value": "10" }] }
          }
