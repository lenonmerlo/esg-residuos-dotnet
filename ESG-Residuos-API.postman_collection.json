            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Ponto Central FIAP\",\n  \"capacityKg\": 500,\n  \"alertVolumeKg\": 400\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/collectionpoints", "host": ["{{baseUrl}}"], "path": ["api", "collectionpoints"] }
          }
        },
        {
          "name": "Update CollectionPoint",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Ponto Central FIAP - Atualizado\",\n  \"capacityKg\": 600,\n  \"alertVolumeKg\": 500\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/collectionpoints/1", "host": ["{{baseUrl}}"], "path": ["api", "collectionpoints", "1"] }
          }
        },
        {
          "name": "Delete CollectionPoint",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/collectionpoints/1", "host": ["{{baseUrl}}"], "path": ["api", "collectionpoints", "1"] }
          }
        }
      ]
    },
